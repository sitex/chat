BOT_TOKEN=

# LLM-бэкенд (auto = cliproxy → grok → claude-cli → claude → ollama)
LLM_BACKEND=auto

# cliproxy (Anthropic-совместимый прокси)
CLIPROXY_BASE_URL=
CLIPROXY_API_KEY=
CLIPROXY_MODEL=claude-sonnet-4-6

# Grok CLI
GROK_BIN=~/.grok/bin/grok
GROK_TIMEOUT=45

# Claude API (прямой)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# Ollama (локальный фолбэк)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# Параметры LLM
LLM_MAX_TOKENS=700
LLM_TIMEOUT=25
LLM_OVERALL_TIMEOUT=60

# История диалога
HISTORY_LIMIT=20

# Для ботов с RAG (путь к корню study-курса)
# STUDY_PATH=/home/rocky/projects/study-your-course

# Админы бота (Telegram user_id через запятую) — /admin_status, /admin_stats, /admin_reset
# ADMIN_IDS=123456789
